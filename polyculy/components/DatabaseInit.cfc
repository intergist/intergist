        arrayAppend(s, "INSERT INTO audit_log (actor_user_id,action_type,entity_type,entity_id,details) VALUES (1,'user_signup','user',1,'User You (Demo) signed up')");
        arrayAppend(s, "INSERT INTO audit_log (actor_user_id,action_type,entity_type,entity_id,details) VALUES (1,'connection_invite','connection',1,'Invited Riley to connect')");
