        arrayAppend(s, "INSERT INTO personal_events (owner_user_id,title,start_time,end_time,timezone_id,event_details,address,visibility_tier) VALUES (1,'Therapy Session',DATEADD('DAY',1,CURRENT_TIMESTAMP),DATEADD('MINUTE',60,DATEADD('DAY',1,CURRENT_TIMESTAMP)),'America/New_York','Weekly therapy appointment','123 Wellness Ave','full_details')");
